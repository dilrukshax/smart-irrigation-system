# Auth Service — local dev bootstrap
# Credentials and full config are loaded from the config_server at startup.
# The config_server must be running (make config-server) with the root .env loaded.
# These vars only tell the service where to find the config server.
CONFIG_ENABLED=true
CONFIG_SERVER_URL=http://localhost:8010
CONFIG_PROFILE=local
CONFIG_SERVICE_NAME=auth_service
CONFIG_TIMEOUT_SEC=3
CONFIG_FAIL_FAST=false
