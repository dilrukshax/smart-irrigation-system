# Irrigation Service Environment Variables

# Application
APP_NAME=Irrigation Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8002

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:8005","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# Cross-service integrations
FORECASTING_SERVICE_URL=http://localhost:8003
CROP_HEALTH_SERVICE_URL=http://localhost:8007
OPTIMIZATION_SERVICE_URL=http://localhost:8004
AUTH_SERVICE_URL=http://localhost:8001

# Database
DATABASE_URL=postgresql://aca_o_user:aca_o_password@localhost:5432/aca_o_db

# Event broker
MQTT_BROKER=localhost
MQTT_PORT=1883
