# Irrigation Service Environment Variables

# Application
APP_NAME=Irrigation Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8002

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:8005","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# Cross-service integrations
FORECASTING_SERVICE_URL=http://forecasting_service:8003
CROP_HEALTH_SERVICE_URL=http://crop_health_and_water_stress_detection:8007

# Event broker
MQTT_BROKER=mosquitto
MQTT_PORT=1883
