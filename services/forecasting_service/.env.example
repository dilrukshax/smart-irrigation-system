# Forecasting Service Environment Variables

# Application
APP_NAME=Forecasting Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8003

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=["http://localhost:8005","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# Runtime behavior
STRICT_LIVE_DATA=false
ML_ONLY_MODE=false

# Cross-service integrations
AUTH_SERVICE_URL=http://auth_service:8001

# Database
DATABASE_URL=postgresql://aca_o_user:aca_o_password@postgres:5432/aca_o_db
