# IoT Telemetry Service Environment Variables

# Application
APP_NAME=IoT Telemetry Service
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8006

# PostgreSQL (NeonDB)
DATABASE_URL=postgresql://neondb_owner:npg_9GmwoYN5exfM@ep-blue-lab-a1tvc7oz-pooler.ap-southeast-1.aws.neon.tech/SIS?sslmode=require&channel_binding=require

# MQTT Broker (Mosquitto running via Docker or locally)
# For Docker: use container name "mosquitto"
# For local dev: use "localhost"
MQTT_BROKER=localhost
MQTT_PORT=1883

# Sensor Calibration (must match ESP32 firmware main.ino values)
SOIL_ADC_DRY=3800
SOIL_ADC_WET=50
WATER_ADC_EMPTY=3800
WATER_ADC_FULL=40

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:8005","http://localhost:8000"]
