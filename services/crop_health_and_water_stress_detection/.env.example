# Crop Health & Water Stress Detection Service

# Application
APP_NAME=Crop Health & Water Stress Detection Service
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8007

# Event broker
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# Auth integration
AUTH_SERVICE_URL=http://auth_service:8001

# Model (override only when needed)
# MODEL_PATH=./notebook/crop_damage_mobilenet.h5

# Image Processing
IMG_SIZE=224

# Default Location (Sri Lanka - Udawalawa region)
DEFAULT_LAT=6.4200
DEFAULT_LON=80.8900
DEFAULT_AREA_KM2=10.0
