# ==============================================================
# Smart Irrigation System — Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.
# ==============================================================

# --- Environment ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Security ---
# Generate a secure key: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL (Docker stack) ---
POSTGRES_USER=aca_o_user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=aca_o_db

# --- PostgreSQL (NeonDB or other cloud DB — used outside Docker) ---
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- MQTT ---
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- InfluxDB ---
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=smart-irrigation
INFLUXDB_BUCKET=sensors

# --- IoT Device Config ---
DEVICE_API_KEYS=
DEVICE_FIELD_MAP=

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=your-grafana-password

# --- Crop Health ML Model ---
IMG_SIZE=224
DEFAULT_LAT=6.4200
DEFAULT_LON=80.8900
DEFAULT_AREA_KM2=10.0

# --- Forecasting runtime flags ---
STRICT_LIVE_DATA=false
ML_ONLY_MODE=false
