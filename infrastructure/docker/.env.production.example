# ==============================================================
# Smart Irrigation System — Production Docker Environment
# Copy to infrastructure/docker/.env.production and replace every
# placeholder before running docker-compose.prod.yml.
# ==============================================================

# --- Runtime profile ---
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
CONFIG_TIMEOUT_SEC=5
STRICT_LIVE_DATA=true
ML_ONLY_MODE=false

# --- Public URLs ---
# Browser origins allowed by the gateway. Comma-separated, no trailing slash.
CORS_ALLOWED_ORIGINS=https://your-domain.example
# JSON list consumed by direct service CORS settings.
CORS_ORIGINS=["https://your-domain.example"]
# Public API base compiled into the Next.js frontend image.
NEXT_PUBLIC_API_BASE_URL=https://your-domain.example/api/v1
WEB_HOST_PORT=80

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-64-char-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- PostgreSQL ---
# For Docker-managed Postgres, keep POSTGRES_HOST=postgres and SSL disabled.
# For managed Postgres, set POSTGRES_HOST/PORT/USER/PASSWORD/DB and POSTGRES_SSLMODE=require,
# or set DATABASE_URL / NEON_DATABASE_URL below.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=smart_irrigation
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=smart_irrigation
POSTGRES_SSLMODE=disable
DATABASE_URL=
NEON_DATABASE_URL=

# Production should use migrations, not app startup table creation.
AUTO_CREATE_SCHEMA=false
ENSURE_CORE_AUTH_SCHEMA=false
SEED_DEFAULT_USERS_ON_STARTUP=false

# --- Bootstrap authority account ---
# The auth migration and service startup ensure this authority user exists.
# Change the password before first production deployment.
ENSURE_BOOTSTRAP_AUTHORITY=true
AUTHORITY_BOOTSTRAP_USERNAME=authority
AUTHORITY_BOOTSTRAP_EMAIL=authority@smartirrigation.com
AUTHORITY_BOOTSTRAP_PASSWORD=replace-with-initial-authority-password
AUTHORITY_BOOTSTRAP_FULL_NAME=System Authority
AUTHORITY_BOOTSTRAP_SCHEME_IDS=scheme-default
AUTHORITY_BOOTSTRAP_RESET_PASSWORD=false

# --- MQTT ---
MQTT_PORT=1883
MQTT_USERNAME=replace-with-mqtt-user
MQTT_PASSWORD=replace-with-mqtt-password

# --- InfluxDB ---
INFLUXDB_ADMIN_PASSWORD=replace-with-strong-influx-admin-password
INFLUXDB_TOKEN=replace-with-strong-influx-token
INFLUXDB_ORG=smart-irrigation
INFLUXDB_BUCKET=sensors

# --- IoT Device Auth and Routing ---
# JSON is safest for values that contain punctuation.
DEVICE_API_KEYS={"esp32-001":"replace-with-device-api-key"}
DEVICE_FIELD_MAP={"esp32-001":"field-001"}

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace-with-strong-grafana-password

# --- Crop Health ML Model ---
# Mount or bake this artifact into the crop health image for production.
CROP_HEALTH_MODEL_PATH=/app/notebook/crop_damage_mobilenet.h5
IMG_SIZE=224
DEFAULT_LAT=6.4200
DEFAULT_LON=80.8900
DEFAULT_AREA_KM2=10.0
