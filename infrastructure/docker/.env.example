# Environment Variables Template
# Copy to .env and fill in values

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# Bootstrap authority login
AUTHORITY_BOOTSTRAP_USERNAME=authority
AUTHORITY_BOOTSTRAP_EMAIL=authority@smartirrigation.com
AUTHORITY_BOOTSTRAP_PASSWORD=authority123
AUTHORITY_BOOTSTRAP_SCHEME_IDS=scheme-default

# Database
MONGODB_URI=mongodb://localhost:27017
POSTGRES_PASSWORD=your-postgres-password

# Redis
REDIS_PASSWORD=your-redis-password

# InfluxDB
INFLUXDB_TOKEN=your-influxdb-token

# Grafana
GF_SECURITY_ADMIN_PASSWORD=your-grafana-password

# Public deployment
WEB_HOST_PORT=80
CORS_ALLOWED_ORIGINS=http://smart-irrigation.centralindia.cloudapp.azure.com
NEXT_PUBLIC_API_BASE_URL=http://smart-irrigation.centralindia.cloudapp.azure.com:8000/api/v1
