# ============================================================
# Smart Irrigation System — Docker Environment Configuration
# Copy this file to .env and fill in real values before deploy
# ============================================================

# --- Security -------------------------------------------------
# CHANGE THIS before any deployment — used to sign JWT tokens
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# --- PostgreSQL -----------------------------------------------
POSTGRES_USER=aca_o_user
POSTGRES_PASSWORD=aca_o_password
POSTGRES_DB=aca_o_db

# --- InfluxDB -------------------------------------------------
INFLUXDB_TOKEN=dev-token-smart-irrigation
INFLUXDB_ORG=smart-irrigation
INFLUXDB_BUCKET=sensors

# --- MQTT (Mosquitto) ----------------------------------------
# Leave blank for anonymous access (development only)
MQTT_USERNAME=
MQTT_PASSWORD=

# --- IoT Device Config ----------------------------------------
# Comma-separated API keys for device authentication
DEVICE_API_KEYS=
# JSON map of device-id to field-id  e.g. {"esp32-001":"field-1"}
DEVICE_FIELD_MAP=

# --- Grafana --------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
