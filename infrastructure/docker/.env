# This file is intentionally minimal.
# The root .env at the project root is the SINGLE SOURCE OF TRUTH.
#
# When running via `make dev` (recommended), docker-compose receives the root .env
# via the --env-file flag automatically.
#
# If running docker-compose directly from this directory without `make`, pass:
#   docker compose --env-file ../../.env up -d
#
# Required vars for docker-compose interpolation (keep in sync with root .env):
POSTGRES_USER=aca_o_user
POSTGRES_PASSWORD=aca_o_password
POSTGRES_DB=aca_o_db
INFLUXDB_TOKEN=dev-token-smart-irrigation
INFLUXDB_ORG=smart-irrigation
INFLUXDB_BUCKET=sensors
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
